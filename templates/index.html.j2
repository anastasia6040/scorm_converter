<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <script src="js/scorm_12_libs.js"></script>
    <script src="js/SCORM_API_wrapper.js"></script>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            background: #f5f5f5;
            color: #333;
        }

        /* Прогресс-бар сверху */
        #progress-bar {
            position: fixed;
            top: 0; left: 0;
            height: 4px;
            background: #4f46e5;
            width: 0%;
            transition: width 0.3s;
            z-index: 1000;
        }

        /* Шапка */
        header {
            position: fixed;
            top: 4px; left: 0; right: 0;
            height: 52px;
            background: #1e1b4b;
            display: flex;
            align-items: center;
            padding: 0 16px;
            gap: 12px;
            z-index: 999;
        }

        #menu-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: white;
            font-size: 1.4em;
            line-height: 1;
        }

        #course-title {
            color: white;
            font-size: 1em;
            font-weight: bold;
            flex: 1;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Боковое меню */
        #sidebar {
            position: fixed;
            top: 0; left: -320px;
            width: 300px;
            height: 100vh;
            background: white;
            box-shadow: 2px 0 12px rgba(0,0,0,0.15);
            z-index: 1100;
            transition: left 0.3s;
            display: flex;
            flex-direction: column;
        }

        #sidebar.open { left: 0; }

        #sidebar-header {
            padding: 20px 16px 12px;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        #sidebar-header h3 { font-size: 1em; color: #333; }

        #close-sidebar {
            background: none;
            border: none;
            font-size: 1.4em;
            cursor: pointer;
            color: #888;
        }

        #sections-list {
            overflow-y: auto;
            flex: 1;
            padding: 12px 0;
        }

        .section-item {
            padding: 10px 16px;
            cursor: pointer;
            font-size: 0.9em;
            color: #555;
            border-left: 3px solid transparent;
            transition: all 0.15s;
        }

        .section-item:hover { background: #f5f4ff; color: #4f46e5; }
        .section-item.active {
            border-left-color: #4f46e5;
            color: #4f46e5;
            background: #f5f4ff;
            font-weight: bold;
        }

        #overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            z-index: 1050;
        }

        #overlay.show { display: block; }

        /* Основной контент */
        main {
            margin-top: 56px;
            min-height: calc(100vh - 56px - 72px);
            display: flex;
            justify-content: center;
            padding: 32px 16px, 200px 16px;
        }

        .section-content {
            display: none;
            max-width: 860px;
            width: 100%;
            padding-bottom: 80px;
        }

        .section-content.active { display: block; }

        /* Типографика */
        .section-content h1 { font-size: 1.8em; margin: 0.8em 0 0.5em; }
        .section-content h2 { font-size: 1.4em; margin: 0.8em 0 0.4em; }
        .section-content h3 { font-size: 1.15em; margin: 0.7em 0 0.3em; }
        .section-content p  { margin: 0.7em 0; line-height: 1.7; }
        .section-content img { max-width: 100%; height: auto; margin: 1em 0; display: block; border-radius: 4px; }
        .section-content table { border-collapse: collapse; width: 100%; margin: 1em 0; }
        .section-content td, .section-content th { border: 1px solid #ccc; padding: 8px 12px; }
        .section-content th { background: #f0f0f0; }
        .section-content ul, .section-content ol { margin: 0.5em 0 0.5em 1.5em; }
        .section-content li { margin: 0.3em 0; line-height: 1.6; }
        .section-content a { color: #4f46e5; }
        .section-content .code-block {
            font-family: monospace;
            font-size: 0.9em;
            background: #f8f8f8;
            border-left: 3px solid #ccc;
            padding: 4px 10px;
            margin: 4px 0;
        }

        /* Нижняя навигация */
        footer {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            height: 60px;
            background: white;
            border-top: 1px solid #e5e5e5;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            z-index: 999;
        }

        .nav-btn {
            background: #4f46e5;
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 8px;
            font-size: 0.95em;
            cursor: pointer;
        }

        .nav-btn:hover { background: #4338ca; }
        .nav-btn:disabled {
          background: #ccc;
          cursor: default;
          opacity: 0.6;
        }
        .nav-btn.finish { background: #16a34a; }
        .nav-btn.finish:hover { background: #15803d; }

        #section-counter {
            font-size: 0.9em;
            color: #888;
        }
    </style>
</head>
<body>

<div id="progress-bar"></div>

<header>
    <button id="menu-btn">☰</button>
    <span id="course-title">{{ title }}</span>
</header>

<!-- Боковое меню -->
<div id="overlay"></div>
<div id="sidebar">
    <div id="sidebar-header">
        <h3>Содержание</h3>
        <button id="close-sidebar">✕</button>
    </div>
    <div id="sections-list">
        {% for section in sections %}
        <div class="section-item {% if loop.first %}active{% endif %}"
             data-index="{{ loop.index0 }}">
            {{ loop.index }}. {{ section.title }}
        </div>
        {% endfor %}
    </div>
</div>

<!-- Контент разделов -->
<main>
    {% for section in sections %}
    <!-- стало -->
    <div class="section-content {% if loop.first %}active{% endif %}"
        id="section-{{ loop.index0 }}">
    <!--SECTION_START_{{ loop.index0 }}-->

        {# Макрос для рендеринга run #}
        {% macro render_run(run) %}
          {%- if run.highlight %}<mark style="background:{{ run.highlight }}">{% endif -%}
          {%- if run.link %}<a href="{{ run.link | e }}" target="_blank">{% endif -%}
          {%- if run.color %}<span style="color:#{{ run.color }}">{% endif -%}
          {%- if run.bold %}<strong>{% endif -%}
          {%- if run.italic %}<em>{% endif -%}
          {%- if run.underline and not run.link %}<u>{% endif -%}
          {{- run.text | e -}}
          {%- if run.underline and not run.link %}</u>{% endif -%}
          {%- if run.italic %}</em>{% endif -%}
          {%- if run.bold %}</strong>{% endif -%}
          {%- if run.color %}</span>{% endif -%}
          {%- if run.link %}</a>{% endif -%}
          {%- if run.highlight %}</mark>{% endif -%}
        {% endmacro %}

        {% set ns = namespace(in_ul=false, in_ol=false) %}

        {# Заголовок раздела #}
        <h1>{{ section.title }}</h1>

        {% for element in section.elements %}

          {% if element.type.value != "list_item" %}
            {% if ns.in_ul %}</ul>{% set ns.in_ul = false %}{% endif %}
            {% if ns.in_ol %}</ol>{% set ns.in_ol = false %}{% endif %}
          {% endif %}

          {% if element.type.value == "heading" %}
            <h{{ element.level }}>{{ element.text | e }}</h{{ element.level }}>

          {% elif element.type.value == "paragraph" %}
            {% set align = element.alignment.value if element.alignment else "left" %}
            {% if element.background %}
              <p class="code-block" style="text-align:{{ align }}">
            {% else %}
              <p style="text-align:{{ align }}">
            {% endif %}
              {% for run in element.runs %}{{ render_run(run) }}{% endfor %}
            </p>

          {% elif element.type.value == "list_item" %}
            {% if element.ordered %}
              {% if not ns.in_ol %}
                {% if ns.in_ul %}</ul>{% set ns.in_ul = false %}{% endif %}
                <ol>{% set ns.in_ol = true %}
              {% endif %}
            {% else %}
              {% if not ns.in_ul %}
                {% if ns.in_ol %}</ol>{% set ns.in_ol = false %}{% endif %}
                <ul>{% set ns.in_ul = true %}
              {% endif %}
            {% endif %}
            <li>{% for run in element.runs %}{{ render_run(run) }}{% endfor %}</li>

          {% elif element.type.value == "image" %}
            <img src="images/{{ element.filename }}" alt="Изображение">
            {% if element.caption %}<p style="text-align:center;color:#666;font-size:0.9em">{{ element.caption | e }}</p>{% endif %}

          {% elif element.type.value == "table" %}
            <table>
              {% for row in element.rows %}
              <tr>{% for cell in row.cells %}<td>{{ cell.text | e }}</td>{% endfor %}</tr>
              {% endfor %}
            </table>

          {% endif %}

        {% endfor %}

        {% if ns.in_ul %}</ul>{% endif %}
        {% if ns.in_ol %}</ol>{% endif %}

    <!--SECTION_END_{{ loop.index0 }}-->
    </div>
    {% endfor %}
</main>

<!-- Нижняя навигация -->
<footer>
    <button class="nav-btn" id="btn-prev" disabled>← Назад</button>
    <span id="section-counter"></span>
    <button class="nav-btn" id="btn-next">Далее →</button>
</footer>

<script>
    const totalSections = {{ sections | length }};
    let current = 0;

    // SCORM init
    var scormReady = false;
    window.onload = function() {
        var result = SCORM_12.LMSInitialize("");
        if (result === "true") scormReady = true;
        updateUI();
    };

    window.onunload = function() {
        if (scormReady) SCORM_12.LMSFinish("");
    };

    function goTo(index) {
        document.querySelectorAll(".section-content").forEach(el => el.classList.remove("active"));
        document.querySelectorAll(".section-item").forEach(el => el.classList.remove("active"));
        document.getElementById("section-" + index).classList.add("active");
        document.querySelector(".section-item[data-index='" + index + "']").classList.add("active");
        current = index;
        updateUI();
        window.scrollTo(0, 0);
        closeSidebar();
    }

    function updateUI() {
      const progress = Math.round(((current + 1) / totalSections) * 100);
      document.getElementById("progress-bar").style.width = progress + "%";
      document.getElementById("section-counter").textContent =
          "Раздел " + (current + 1) + " из " + totalSections;

      // ← исправлено: явно ставим и снимаем disabled
      const prevBtn = document.getElementById("btn-prev");
      prevBtn.disabled = current === 0;

      const nextBtn = document.getElementById("btn-next");
      if (current === totalSections - 1) {
          nextBtn.textContent = "Завершить ✓";
          nextBtn.classList.add("finish");
      } else {
          nextBtn.textContent = "Далее →";
          nextBtn.classList.remove("finish");
      }
      nextBtn.disabled = false;
    }

    document.getElementById("btn-prev").onclick = function() {
        if (current > 0) goTo(current - 1);
    };

    document.getElementById("btn-next").onclick = function() {
        if (current < totalSections - 1) {
            goTo(current + 1);
        } else {
            // Последний раздел — завершаем курс
            if (scormReady) {
                SCORM_12.LMSSetValue("cmi.core.lesson_status", "passed");
                SCORM_12.LMSCommit("");
                SCORM_12.LMSFinish("");
                scormReady = false;
            }
            document.getElementById("btn-next").textContent = "Пройдено ✓";
            document.getElementById("btn-next").disabled = true;
        }
    };

    // Боковое меню
    document.getElementById("menu-btn").onclick = function() {
        document.getElementById("sidebar").classList.add("open");
        document.getElementById("overlay").classList.add("show");
    };

    function closeSidebar() {
        document.getElementById("sidebar").classList.remove("open");
        document.getElementById("overlay").classList.remove("show");
    }

    document.getElementById("close-sidebar").onclick = closeSidebar;
    document.getElementById("overlay").onclick = closeSidebar;

    document.querySelectorAll(".section-item").forEach(function(item) {
        item.onclick = function() {
            goTo(parseInt(this.dataset.index));
        };
    });
</script>
</body>
</html>